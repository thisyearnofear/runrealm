{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "@runrealm/shared-core/*": ["./packages/shared-core/*"],
      "@runrealm/shared-types/*": ["./packages/shared-types/*"],
      "@runrealm/shared-utils/*": ["./packages/shared-utils/*"],
      "@runrealm/shared-blockchain/*": ["./packages/shared-blockchain/*"]
    }
  },
  "include": ["packages/**/*", "types/**/*"],
  "exclude": [
    "node_modules",
    "config",
    "docs",
    "static",
    "public",
    "build",
    "artifacts",
    "tools",
    "infrastructure",
    "test"
  ]
}
