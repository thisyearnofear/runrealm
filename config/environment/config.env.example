# RunRealm Environment Variables
# Copy this file to .env and fill in your actual values.
# Do NOT commit real credentials — see scripts/secrets-scan.sh.

# Mapbox Access Token (required for map functionality)
# Get one at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Google Generative AI API Key (for AI features)
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_google_api_key_here
# Web3 Configuration (for blockchain features)
PRIVATE_KEY=your_private_key_here
ZETACHAIN_RPC_URL=https://zetachain-athens-evm.blockpi.network/v1/rpc/public

# Phase 3 additive boost contract (deployed on ZetaChain Athens).
RUNREALM_BOOST_ADDRESS=

# --- Zama Protocol FHEVM (confidential territory defense) ---
# Sepolia is the FHEVM host chain. A public RPC is used by default,
# override here for a private endpoint (Infura/Alchemy).
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Etherscan v2 API key (optional) — enables `hardhat verify` on Sepolia.
ETHERSCAN_API_KEY=your_etherscan_api_key_here
# Deployed ConfidentialTerritoryDefense address (filled after deploy).
RUNREALM_CONFIDENTIAL_DEFENSE_ADDRESS=

# Feature Flags
ENABLE_WEB3=true
ENABLE_AI_FEATURES=true
ENABLE_CROSS_CHAIN=true

# Development
NODE_ENV=development
DEBUG=runrealm:*

# Strava API Configuration
# Create an app at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback