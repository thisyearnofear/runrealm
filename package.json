{
  "name": "runrealm-monorepo",
  "version": "2.0.0",
  "description": "ZetaChain fitness GameFi app - claim and defend real-world running territories as NFTs",
  "private": true,
  "scripts": {
    "build": "npm run build:shared && npm run build:web",
    "build:web": "npm run build --workspace=@runrealm/web",
    "build:mobile": "echo 'Mobile build requires React Native environment'",
    "build:shared": "npm run build --workspace=@runrealm/shared-core && npm run build --workspace=@runrealm/shared-types && npm run build --workspace=@runrealm/shared-utils && npm run build --workspace=@runrealm/shared-blockchain",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:backend\"",
    "dev:web": "npm run dev --workspace=@runrealm/web",
    "dev:backend": "node server.js",
    "test": "npm run test --workspaces",
    "test:unit": "npm run test:unit --workspaces",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:errors": "biome check --diagnostic-level=error .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "setup:env": "cp config/environment/.env.template .env && cp config/environment/.env.production.template .env.production",
    "clean": "rm -rf packages/*/dist packages/*/node_modules apps/*/dist apps/*/node_modules build artifacts",
    "install:all": "npm install && npm run install --workspaces",
    "sync:rules": "node scripts/build/sync-game-rules.mjs",
    "sync:check": "node scripts/build/sync-game-rules.mjs --check",
    "ci:rules-drift": "npm run sync:check"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@biomejs/biome": "2.3.8",
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/jest": "^30.0.0",
    "@types/mapbox__mapbox-sdk": "^0.16.3",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "concurrently": "^8.2.0",
    "encrypted-types": "^0.0.4",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "jest-environment-jsdom": "^30.4.1",
    "lefthook": "^1.7.0",
    "react-dom": "^19.2.4",
    "react-native-worklets": "^0.10.2",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/contracts": "^5.4.0",
    "buffer": "^6.0.3",
    "dotenv": "^17.2.3",
    "process": "^0.11.10",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "@babel/core": "^7.22.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffbdye/RunRealm.git"
  },
  "author": "Jeff Dye",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/jeffbdye/RunRealm/issues"
  },
  "homepage": "https://github.com/jeffbdye/RunRealm#readme"
}
